{
  "name": "code-container",
  "version": "2.0.2",
  "description": "Manage isolated Docker containers for running coding tools on different projects",
  "main": "dist/main.js",
  "bin": {
    "container": "./dist/main.js"
  },
  "files": [
    "dist",
    "scripts",
    "Dockerfile"
  ],
  "scripts": {
    "build": "tsc && chmod u+x dist/main.js",
    "clean": "rm -rf dist",
    "start": "node dist/main.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "docker",
    "container",
    "development",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
