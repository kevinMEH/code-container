{
  "name": "code-container",
  "version": "2.4.2",
  "description": "Manage isolated Docker containers for running coding tools on different projects",
  "main": "dist/main.js",
  "bin": {
    "container": "dist/main.js"
  },
  "files": [
    "dist",
    "scripts",
    "resources"
  ],
  "scripts": {
    "build": "tsc && chmod u+x dist/main.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --project tsconfig.test.json",
    "test": "vitest run",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "format": "prettier --write --ignore-unknown .",
    "precommit": "bash scripts/precommit.sh",
    "prepare": "husky",
    "postinstall": "node scripts/postinstall.js",
    "publish-latest": "npm run clean && npm run build && npm publish",
    "publish-nightly": "npm run clean && npm run build && npm publish --tag nightly",
    "install-local": "npm run clean && npm run build && npm link"
  },
  "author": "kevinMEH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinMEH/code-container.git"
  },
  "bugs": "https://github.com/kevinMEH/code-container/issues",
  "homepage": "https://github.com/kevinMEH/code-container",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.37",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "memfs": "^4.57.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@types/shell-quote": "^1.7.5",
    "shell-quote": "^1.7.4",
    "zod": "^4.3.6"
  },
  "keywords": [
    "docker",
    "container",
    "development",
    "cli",
    "opencode",
    "open code",
    "claude code",
    "claude",
    "codex",
    "openai",
    "anthropic",
    "chatbot",
    "harness",
    "vibe coding",
    "gemini",
    "gemini cli",
    "copilot",
    "github copilot"
  ]
}
